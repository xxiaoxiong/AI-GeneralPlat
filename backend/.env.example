# Application
APP_NAME="AI-GeneralPlat"
APP_VERSION="2.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (MySQL)
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/ai_plat
DATABASE_SYNC_URL=mysql+pymysql://root:123456@localhost:3306/ai_plat

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma

# File Storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=100

# Default Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
ADMIN_USERNAME=admin

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Agent 执行引擎 ──────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=15
AGENT_MAX_TOOL_RETRIES=2
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_MAX_SAME_TOOL_CALLS=3
AGENT_TEMPERATURE=0.3
AGENT_ENABLE_SELF_VERIFY=true
AGENT_ENABLE_SOURCE_CITATION=true

# ── 推理层（30B 模型优化）────────────────────────────────────────────────────
INFERENCE_MAX_CONTEXT_TOKENS=8192
INFERENCE_MAX_OUTPUT_TOKENS=4096
INFERENCE_KV_CACHE_MAX_MB=4096
INFERENCE_CONCURRENT_REQUESTS=2
INFERENCE_REQUEST_QUEUE_SIZE=20
INFERENCE_REQUEST_TIMEOUT=120

# ── 上下文管理 ──────────────────────────────────────────────────────────────
CONTEXT_SLIDING_WINDOW_TURNS=6
CONTEXT_MAX_HISTORY_TOKENS=2048
CONTEXT_SUMMARY_THRESHOLD=4096
CONTEXT_PIN_SYSTEM_PROMPT=true
CONTEXT_PIN_ORIGINAL_TASK=true

# ── 记忆系统 ────────────────────────────────────────────────────────────────
MEMORY_SHORT_TERM_MAX_TURNS=6
MEMORY_LONG_TERM_MAX_ITEMS=200
MEMORY_IMPORTANCE_THRESHOLD=0.5
MEMORY_AUTO_DISTILL=true
MEMORY_STRUCTURED_STORE=true
MEMORY_CONFLICT_STRATEGY=newer
MEMORY_DB_PATH=./data/memory

# ── 幻觉抑制 ────────────────────────────────────────────────────────────────
HALLUCINATION_FACT_CHECK=true
HALLUCINATION_MAX_VERIFY_ROUNDS=2
HALLUCINATION_FORCE_SOURCE=true
HALLUCINATION_UNCERTAINTY_EXPR=true

# ── 监控与日志 ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_AGENT_TRACE=true
LOG_TOOL_CALLS=true
LOG_PERFORMANCE=true
MONITOR_ENABLE=true
MONITOR_SLOW_THRESHOLD_MS=5000

# ── 搜索引擎（内网环境）────────────────────────────────────────────────────
SEARXNG_URL=                          # SearXNG 实例地址，如 http://localhost:8888（留空则使用外网引擎）
SEARCH_TIMEOUT=25                     # 搜索超时秒数

# ── 稳定性 ──────────────────────────────────────────────────────────────────
HOT_RELOAD_TOOLS=true
HOT_RELOAD_PROMPTS=true
SESSION_ISOLATION=true
DETERMINISTIC_MODE=false
CHECKPOINT_ENABLED=true
CHECKPOINT_DIR=./data/checkpoints
